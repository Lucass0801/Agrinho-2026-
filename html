<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Agrinho - Sustentabilidade no Campo</title>

  <link rel="stylesheet" href="style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

  <!-- MENU -->
  <header>
    <nav class="navbar">
      <h1 class="logo">🌱 AGRINHO</h1>

      <ul class="nav-links">
        <li><a href="#inicio">Início</a></li>
        <li><a href="#sobre">Sobre</a></li>
        <li><a href="#praticas">Práticas</a></li>
        <li><a href="#impacto">Impacto</a></li>
      </ul>
    </nav>
  </header>

  <!-- HERO -->
  <section class="hero" id="inicio">
    <div class="overlay"></div>

    <div class="hero-content">
      <h2>Sustentabilidade no Campo</h2>

      <p>
        Produzir alimentos preservando a natureza é garantir um futuro melhor
        para todos.
      </p>

      <a href="#sobre" class="btn">Saiba Mais</a>
    </div>
  </section>

  <!-- SOBRE -->
  <section class="sobre" id="sobre">

    <div class="section-title">
      <h2>🌿 O que é sustentabilidade?</h2>
    </div>

    <div class="sobre-container">

      <div class="card">
        <h3>🌎 Preservação</h3>

        <p>
          A sustentabilidade busca proteger o meio ambiente,
          evitando desperdícios e reduzindo impactos na natureza.
        </p>
      </div>

      <div class="card">
        <h3>🚜 Agricultura Consciente</h3>

        <p>
          O uso responsável da água, do solo e dos recursos naturais
          ajuda na produção sustentável no campo.
        </p>
      </div>

      <div class="card">
        <h3>💚 Futuro Melhor</h3>

        <p>
          Pequenas atitudes hoje podem garantir alimentos e qualidade
          de vida para as próximas gerações.
        </p>
      </div>

    </div>
  </section>

  <!-- PRÁTICAS -->
  <section class="praticas" id="praticas">

    <div class="section-title">
      <h2>♻️ Práticas Sustentáveis</h2>
    </div>

    <div class="praticas-grid">

      <div class="pratica-card">
        <span>💧</span>
        <h3>Economia de Água</h3>
        <p>
          Sistemas de irrigação inteligentes ajudam a evitar desperdícios.
        </p>
      </div>

      <div class="pratica-card">
        <span>🌱</span>
        <h3>Reflorestamento</h3>
        <p>
          Plantar árvores ajuda a proteger rios, solos e animais.
        </p>
      </div>

      <div class="pratica-card">
        <span>☀️</span>
        <h3>Energia Limpa</h3>
        <p>
          Painéis solares reduzem a poluição e geram energia renovável.
        </p>
      </div>

      <div class="pratica-card">
        <span>🚜</span>
        <h3>Tecnologia no Campo</h3>
        <p>
          Máquinas modernas aumentam a produtividade sem prejudicar a natureza.
        </p>
      </div>

    </div>
  </section>

  <!-- IMPACTO -->
  <section class="impacto" id="impacto">

    <div class="impacto-content">

      <h2>🌍 Nosso Papel</h2>

      <p>
        Todos podem contribuir para um campo mais sustentável:
        agricultores, estudantes e toda a sociedade.
      </p>

      <button>Preservar é Cultivar o Futuro</button>

    </div>

  </section>

  <!-- RODAPÉ -->
  <footer>
    <p>
      Projeto Agrinho 2026 • Sustentabilidade no Campo 🌱
    </p>
  </footer>

</body>
</html>
